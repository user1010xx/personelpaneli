# Personel Panel Environment Variables

# Database
DATABASE_URL=postgresql://user:password@host:5432/database
POSTGRES_USER=personelpanel
POSTGRES_PASSWORD=change-me
POSTGRES_DB=personelpanel

# Secret Key - CHANGE THIS IN PRODUCTION (min 32 characters)
SECRET_KEY=replace-with-random-32-plus-character-secret
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password
INITIAL_ADMIN_FULL_NAME=Administrator

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# API
API_TITLE=Personel Panel API
DEBUG=False

# Google Docs Integration
DOCS_PUANTAJ_ID=
DOCS_UYARILAR_ID=
DOCS_WHATSAPP_ID=
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_CREDENTIALS_HOST_PATH=./credentials.json
GOOGLE_CREDENTIALS_JSON=
