{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "VITE_API_URL": "https://${{ personelpaneli.RAILWAY_PUBLIC_DOMAIN }}/api"
    }
  },
  "deploy": {
    "startCommand": "serve -s dist -l 3000"
  }
}
