{
  "services": [
    {
      "name": "personelpaneli",
      "type": "docker",
      "build": {
        "dockerfilePath": "Dockerfile.backend",
        "context": "."
      },
      "startCommand": "python main.py"
    },
    {
      "name": "frontend",
      "type": "docker",
      "build": {
        "dockerfilePath": "Dockerfile",
        "context": "frontend"
      },
      "startCommand": "serve -s dist -l 3000"
    }
  ]
}
